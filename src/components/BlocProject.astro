---
import Chip from './Chip.astro';

interface Props {
  clientLight: string;
  clientBold: string;
  description: string;
  chips: string[];
  imageSrc: string;
  backgroundSrc: string;
  href?: string;
}

const { clientLight, clientBold, description, chips, imageSrc, backgroundSrc, href = '#' } = Astro.props;
---

<a class="bloc-project" href={href}>
  <div class="bloc-project__bg">
    <img src={backgroundSrc} alt="" loading="lazy" />
    <div class="bloc-project__overlay"></div>
  </div>

  <div class="bloc-project__content">
    <div class="bloc-project__image">
      <img src={imageSrc} alt={`${clientLight} ${clientBold}`} loading="lazy" />
    </div>

    <div class="bloc-project__info">
      <div class="bloc-project__title">
        <span class="h1-light">{clientLight}</span>
        <span class="h1-bold">{clientBold}</span>
      </div>

      <p class="text-md bloc-project__desc">{description}</p>

      <div class="bloc-project__chips">
        {chips.map((chip) => <Chip label={chip} />)}
      </div>

      <div class="bloc-project__button" aria-hidden="true">
        <svg width="12" height="16" viewBox="0 0 12 16" fill="none"><path d="M2 2L10 8L2 14" stroke="#031334" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>
    </div>
  </div>
</a>

<style>
  .bloc-project {
    display: block;
    position: relative;
    z-index: 2;
    width: 100%;
    padding: var(--space-48) var(--content-padding);
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  .bloc-project__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .bloc-project__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .bloc-project__overlay {
    position: absolute;
    inset: 0;
    background: var(--color-overlay);
  }

  .bloc-project__content {
    position: relative;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-16);
  }

  .bloc-project__image {
    flex-shrink: 0;
    width: 600px;
    min-width: 300px;
  }

  .bloc-project__image img {
    width: 100%;
    height: auto;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .bloc-project:hover .bloc-project__image img {
    transform: scale(1.03);
  }

  .bloc-project__info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
    min-width: 300px;
    max-width: 600px;
  }

  .bloc-project__title {
    display: flex;
    flex-direction: column;
  }

  .bloc-project__desc {
    color: var(--color-cream);
  }

  .bloc-project__chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-16);
  }

  .bloc-project__button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--space-56);
    height: var(--space-56);
    background-color: var(--color-cream);
    border-radius: var(--radius-full);
    flex-shrink: 0;
    transition: transform 0.3s ease, background-color 0.2s ease;
  }

  .bloc-project:hover .bloc-project__button {
    transform: scale(1.1);
    background-color: var(--color-red-300);
  }
</style>
