---
import Chip from './Chip.astro';

interface Props {
  clientLight: string;
  clientBold: string;
  description: string;
  chips: string[];
  imageSrc: string;
  backgroundSrc: string;
  href?: string;
  bgColor?: string;
}

const { clientLight, clientBold, description, chips, imageSrc, backgroundSrc, href = '#', bgColor } = Astro.props;
---

<a class="bloc-project fade-in" href={href} data-bg-color={bgColor}>
  <div class="bloc-project__bg">
    <img src={backgroundSrc} alt="" loading="lazy" />
    <div class="bloc-project__overlay"></div>
  </div>

  <div class="bloc-project__content">
    <div class="bloc-project__image">
      <img src={imageSrc} alt={`${clientLight} ${clientBold}`} loading="lazy" />
    </div>

    <div class="bloc-project__info">
      <div class="bloc-project__title">
        <span class="h1-light">{clientLight}</span>
        <span class="h1-bold">{clientBold}</span>
      </div>

      <p class="text-md bloc-project__desc">{description}</p>

      <div class="bloc-project__chips">
        {chips.map((chip) => <Chip label={chip} />)}
      </div>

      <div class="bloc-project__button" aria-hidden="true">
        <svg width="12" height="16" viewBox="0 0 12 16" fill="none"><path d="M2 2L10 8L2 14" stroke="#031334" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>
    </div>
  </div>
</a>

<style>
  .bloc-project {
    display: block;
    position: relative;
    z-index: 2;
    width: 100%;
    padding: var(--space-48) var(--content-padding);
    text-decoration: none;
    color: inherit;
    cursor: default;
    overflow: hidden;
  }

  .bloc-project__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .bloc-project__bg img {
    position: absolute;
    top: -25%;
    left: 0;
    width: 100%;
    height: 150%;
    object-fit: cover;
    will-change: transform;
  }

  .bloc-project__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 17, 40, 0.95);
    transition: background-color 0.5s ease;
  }

  .bloc-project__content {
    position: relative;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-48);
    cursor: pointer;
    width: fit-content;
    margin: 0 auto;
  }

  .bloc-project__image {
    flex-shrink: 0;
    width: 510px;
    min-width: 300px;
  }

  .bloc-project__image img {
    width: 100%;
    height: auto;
    object-fit: cover;
    will-change: transform;
    transition: transform 0.4s ease;
    transform: translateY(var(--parallax-y, 0px)) rotate(var(--parallax-rot, 0deg));
  }

  .bloc-project__content:hover .bloc-project__image img {
    transform: translateY(var(--parallax-y, 0px)) rotate(var(--parallax-rot, 0deg)) scale(1.05);
  }

  .bloc-project__info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
    min-width: 300px;
    max-width: 600px;
  }

  .bloc-project__title {
    display: flex;
    flex-direction: column;
  }

  .bloc-project__desc {
    color: var(--color-cream);
  }

  .bloc-project__chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-16);
  }

  .bloc-project__button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--space-56);
    height: var(--space-56);
    background-color: var(--color-cream);
    border-radius: var(--radius-full);
    flex-shrink: 0;
    transition: transform 0.3s ease, background-color 0.2s ease;
  }

  .bloc-project__content:hover .bloc-project__button {
    transform: scale(1.1);
    background-color: var(--color-red-300);
  }

  @media (max-width: 768px) {
    .bloc-project__image {
      width: 100%;
      min-width: 0;
    }

    .bloc-project__info {
      min-width: 0;
      width: 100%;
    }
  }
</style>

<script>
  function initProjectBlocs() {
    const projects = document.querySelectorAll('.bloc-project') as NodeListOf<HTMLAnchorElement>;

    // ── Parallax on scroll ──
    function onScroll() {
      const viewH = window.innerHeight;
      const viewCenter = viewH / 2;

      projects.forEach((project) => {
        const rect = project.getBoundingClientRect();
        const blockCenter = rect.top + rect.height / 2;
        const distFromCenter = Math.abs(blockCenter - viewCenter);
        const maxDist = viewH * 0.4;

        const proximity = Math.max(0, 1 - distFromCenter / maxDist);

        const overlay = project.querySelector('.bloc-project__overlay') as HTMLElement;
        if (overlay) {
          const overlayAlpha = 0.95 - proximity * 0.4;
          overlay.style.backgroundColor = `rgba(0, 17, 40, ${overlayAlpha})`;
        }

        const scrollOffset = (rect.top - viewCenter) * 0.15;

        const bgImg = project.querySelector('.bloc-project__bg img') as HTMLElement;
        if (bgImg) {
          bgImg.style.transform = `translateY(${scrollOffset}px)`;
        }

        const mockupImg = project.querySelector('.bloc-project__image img') as HTMLElement;
        if (mockupImg) {
          const mockupOffset = (rect.top - viewCenter) * 0.08 + 40;
          mockupImg.style.setProperty('--parallax-y', `${mockupOffset}px`);
          const rotation = (rect.top - viewCenter) * 0.008;
          mockupImg.style.setProperty('--parallax-rot', `${rotation}deg`);
        }
      });
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // ── Circle transition on click ──
    projects.forEach((project) => {
      project.addEventListener('click', (e) => {
        e.preventDefault();
        const href = project.getAttribute('href');
        if (!href || href === '#') return;

        const btn = project.querySelector('.bloc-project__button') as HTMLElement;
        if (!btn) { window.location.href = href; return; }

        const btnRect = btn.getBoundingClientRect();
        const cx = btnRect.left + btnRect.width / 2;
        const cy = btnRect.top + btnRect.height / 2;

        // Scale needed to cover entire viewport from button center
        const maxX = Math.max(cx, window.innerWidth - cx);
        const maxY = Math.max(cy, window.innerHeight - cy);
        const maxRadius = Math.sqrt(maxX * maxX + maxY * maxY);
        const btnRadius = btnRect.width / 2;
        const targetScale = (maxRadius / btnRadius) * 1.1;

        // Helper: create + animate a circle from button position
        function spawnCircle(color: string, zIndex: number, duration: string) {
          const el = document.createElement('div');
          el.style.position = 'fixed';
          el.style.left = (cx - btnRadius) + 'px';
          el.style.top = (cy - btnRadius) + 'px';
          el.style.width = (btnRadius * 2) + 'px';
          el.style.height = (btnRadius * 2) + 'px';
          el.style.borderRadius = '50%';
          el.style.backgroundColor = color;
          el.style.transform = 'scale(0)';
          el.style.zIndex = '' + zIndex;
          el.style.pointerEvents = 'none';
          el.style.willChange = 'transform, opacity';
          el.style.opacity = '1';
          document.body.appendChild(el);
          // Force reflow so scale(0) is painted before animating
          el.getBoundingClientRect();
          el.style.transition = 'transform ' + duration + ' cubic-bezier(0.55, 0, 1, 0.45)';
          el.style.transform = 'scale(' + targetScale + ')';
          return el;
        }

        // Circle 1 — cream
        const circle1 = spawnCircle('#FEF7E1', 9998, '0.5s');

        // Circle 2 — project bg color, after 100ms
        const bgColor = project.getAttribute('data-bg-color');
        setTimeout(() => {
          const circle2 = spawnCircle(bgColor || '#031334', 9999, '0.45s');

          // Once circle 2 covers the screen, fade out both circles to reveal the new page
          setTimeout(() => {
            circle1.style.transition = 'opacity 0.4s ease';
            circle2.style.transition = 'opacity 0.4s ease';
            circle1.style.opacity = '0';
            circle2.style.opacity = '0';

            // Navigate after fade-out completes
            setTimeout(() => {
              window.location.href = href;
            }, 400);
          }, 450);
        }, 100);
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initProjectBlocs);
  document.addEventListener('astro:page-load', initProjectBlocs);
</script>
