---
interface Props {
  title: string;
  description: string;
  imageSrc: string;
  href?: string;
}

const { title, description, imageSrc, href } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag class="bloc-skills fade-in" href={href}>
  <h3 class="h2-bold">{title}</h3>
  <p class="text-md bloc-skills__desc">{description}</p>
  <div class="bloc-skills__image">
    <img src={imageSrc} alt={title} loading="lazy" />
  </div>
</Tag>

<style>
  .bloc-skills {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 22px;
    min-width: 240px;
    text-decoration: none;
    color: inherit;
  }

  .bloc-skills__desc {
    color: var(--color-blue-400);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .bloc-skills__image {
    width: 100%;
    aspect-ratio: 1;
    border-radius: var(--radius-sm);
    overflow: hidden;
    margin-top: auto;
  }

  .bloc-skills__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .bloc-skills:hover .bloc-skills__image img {
    transform: scale(1.05);
  }
</style>
