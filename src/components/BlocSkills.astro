---
interface Props {
  title: string;
  description: string;
  imageSrc: string;
}

const { title, description, imageSrc } = Astro.props;
---

<div class="bloc-skills">
  <h3 class="h2-bold">{title}</h3>
  <p class="text-md bloc-skills__desc">{description}</p>
  <div class="bloc-skills__image">
    <img src={imageSrc} alt={title} loading="lazy" />
  </div>
</div>

<style>
  .bloc-skills {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 22px;
    min-width: 200px;
  }

  .bloc-skills__desc {
    color: var(--color-blue-400);
  }

  .bloc-skills__image {
    width: 100%;
    aspect-ratio: 1;
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  .bloc-skills__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
