---
interface Props {
  label: string;
}

const { label } = Astro.props;
---

<span class="chip">{label}</span>

<style>
  .chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 4px 12px;
    background-color: var(--color-blue-500);
    color: var(--color-cream);
    border-radius: var(--radius-full);
    font-size: 16px;
    font-weight: var(--font-weight-regular);
    white-space: nowrap;
  }
</style>
