---
interface Props {
  logoLight?: string;
  logoDark?: string;
}

const {
  logoLight = '/images/logo/Icon 180px - Dark.png',
  logoDark = '/images/logo/Icon 180px - Light.png',
} = Astro.props;
---

<a class="menu-home" href="/" aria-label="Retour à l'accueil">
  <img class="menu-home__logo menu-home__logo--light" src={logoLight} alt="AJ" width="48" height="44" />
  <img class="menu-home__logo menu-home__logo--dark" src={logoDark} alt="AJ" width="48" height="44" />
</a>

<style>
  .menu-home {
    position: fixed;
    top: 0;
    left: var(--margin-page-up);
    z-index: 100;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    width: var(--header-width);
    padding: 12px 12px;
    background-color: var(--color-blue-850);
    border-radius: 0 0 var(--space-24) var(--space-24);
    transition: background-color 0.2s ease;
  }

  .menu-home:hover {
    background-color: var(--color-cream);
  }

  .menu-home:active {
    background-color: var(--color-red-300);
  }

  .menu-home__logo {
    width: 48px;
    height: auto;
    aspect-ratio: 76 / 70;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .menu-home__logo.loaded {
    opacity: 1;
  }

  .menu-home__logo--dark {
    display: none;
  }

  .menu-home:hover .menu-home__logo--light,
  .menu-home:active .menu-home__logo--light {
    display: none;
  }

  .menu-home:hover .menu-home__logo--dark,
  .menu-home:active .menu-home__logo--dark {
    display: block;
  }

  @media (max-width: 768px) {
    .menu-home__logo {
      width: 36px;
    }
  }
</style>

<script>
  function initMenuLogos() {
    document.querySelectorAll('.menu-home__logo').forEach((img) => {
      const el = img as HTMLImageElement;
      if (el.complete) {
        el.classList.add('loaded');
      } else {
        el.addEventListener('load', () => el.classList.add('loaded'));
      }
    });
  }
  document.addEventListener('DOMContentLoaded', initMenuLogos);
  document.addEventListener('astro:page-load', initMenuLogos);
</script>
