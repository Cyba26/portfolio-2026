---
interface Props {
  logoLight?: string;
  logoDark?: string;
}

const {
  logoLight = '/images/logo/Icon 180px - Dark.png',
  logoDark = '/images/logo/Icon 180px - Light.png',
} = Astro.props;
---

<a class="menu-home" href="/" aria-label="Retour à l'accueil">
  <img class="menu-home__logo menu-home__logo--light" src={logoLight} alt="AJ" width="48" height="44" />
  <img class="menu-home__logo menu-home__logo--dark" src={logoDark} alt="AJ" width="48" height="44" />
</a>

<style>
  .menu-home {
    position: fixed;
    top: 0;
    left: var(--space-32);
    z-index: 100;
    display: flex;
    align-items: start;
    justify-content: center;
    width: 72px;
    padding: 20px 12px 12px;
    background-color: var(--color-blue-850);
    border-radius: 0 0 var(--radius-sm) var(--radius-sm);
    transition: background-color 0.2s ease;
  }

  .menu-home:hover {
    background-color: var(--color-cream);
  }

  .menu-home__logo {
    width: 48px;
    height: auto;
    aspect-ratio: 76 / 70;
    object-fit: cover;
  }

  .menu-home__logo--dark {
    display: none;
  }

  .menu-home:hover .menu-home__logo--light {
    display: none;
  }

  .menu-home:hover .menu-home__logo--dark {
    display: block;
  }
</style>
