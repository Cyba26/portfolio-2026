---
interface Props {
  title: string;
  chips: string[];
  imageSrc: string;
  href: string;
}

const { title, chips, imageSrc, href } = Astro.props;
---

<a class="project-thumbnail" href={href}>
  <div class="project-thumbnail__image">
    <img src={imageSrc} alt={title} loading="lazy" />
  </div>
  <h3 class="h3-bold project-thumbnail__title">{title}</h3>
  <div class="project-thumbnail__chips">
    {chips.map((chip) => <span class="project-thumbnail__chip">{chip}</span>)}
  </div>
</a>

<style>
  .project-thumbnail {
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
    text-decoration: none;
    color: inherit;
    flex: 1;
    min-width: 280px;
  }

  .project-thumbnail__image {
    width: 100%;
    height: 297px;
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .project-thumbnail__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .project-thumbnail:hover .project-thumbnail__image img {
    transform: scale(1.03);
  }

  .project-thumbnail__title {
    color: var(--color-cream);
  }

  .project-thumbnail__chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-8);
  }

  .project-thumbnail__chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 4px 12px;
    background-color: var(--color-blue-500);
    color: var(--color-cream);
    border-radius: var(--radius-full);
    font-size: 16px;
    font-weight: var(--font-weight-regular);
    white-space: nowrap;
  }
</style>
