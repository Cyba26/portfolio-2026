---
import Chip from './Chip.astro';

interface Props {
  titleBold: string;
  titleRegular: string;
  chips: string[];
  imageSrc: string;
  href: string;
}

const { titleBold, titleRegular, chips, imageSrc, href } = Astro.props;
---

<a class="project-thumbnail" href={href}>
  <div class="project-thumbnail__image">
    <img src={imageSrc} alt={`${titleBold} ${titleRegular}`} loading="lazy" />
  </div>
  <div class="project-thumbnail__title">
    <span class="project-thumbnail__title-bold">{titleBold}</span>
    <span class="project-thumbnail__title-regular">{titleRegular}</span>
  </div>
  <div class="project-thumbnail__chips">
    {chips.map((chip) => <Chip label={chip} />)}
  </div>
</a>

<style>
  .project-thumbnail {
    display: flex;
    flex-direction: column;
    gap: var(--space-24);
    text-decoration: none;
    color: inherit;
    flex: 1;
    min-width: 200px;
  }

  .project-thumbnail__image {
    width: 100%;
    height: 297px;
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .project-thumbnail__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .project-thumbnail:hover .project-thumbnail__image img {
    transform: scale(1.03);
  }

  .project-thumbnail__title {
    display: flex;
    gap: var(--space-8);
    align-items: baseline;
    font-size: var(--font-size-h3);
    letter-spacing: var(--letter-spacing-h3);
    line-height: normal;
    color: var(--color-cream);
    white-space: nowrap;
  }

  .project-thumbnail__title-bold {
    font-weight: var(--font-weight-bold);
  }

  .project-thumbnail__title-regular {
    font-weight: var(--font-weight-regular);
  }

  .project-thumbnail__chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-16);
  }
</style>
