---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Arthur Jeunechamp — Product Designer',
  description = 'Product Designer / Designer UI-UX avec plus de 5 ans d\'expérience en agence et secteur public. J\'accompagne les équipes de l\'idéation à la livraison : ateliers de cadrage, conception UX/UI, et review avec les devs.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://www.arthurjeunechamp.com');
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Arthur Jeunechamp" />
    <meta name="theme-color" content="#031334" />
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/images/logo/Icon_SVG_Light.svg" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/svg+xml" href="/images/logo/Icon_SVG_Dark.svg" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/png" href="/images/logo/Icon 180px - Dark.png" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/png" href="/images/logo/Icon 180px - Light.png" media="(prefers-color-scheme: light)" />
    <link rel="apple-touch-icon" href="/images/logo/Icon 180px - Light.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Arthur Jeunechamp — Portfolio" />
    <meta property="og:image" content="https://www.arthurjeunechamp.com/images/metadonnees/Social Preview UI UX.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://www.arthurjeunechamp.com/images/metadonnees/Social Preview UI UX.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=SUSE:wght@300;400;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script>
      import { inject } from '@vercel/analytics';
      inject();
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/tokens.css';
  @import '../styles/reset.css';
  @import '../styles/typography.css';
</style>

<script>
  function initImgLoad() {
    document.querySelectorAll('img').forEach((img) => {
      if (img.complete) {
        img.classList.add('img-loaded');
      } else {
        img.addEventListener('load', () => img.classList.add('img-loaded'));
      }
    });
  }

  document.addEventListener('DOMContentLoaded', initImgLoad);
  document.addEventListener('astro:page-load', initImgLoad);
</script>
