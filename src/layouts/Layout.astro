---
interface Props {
  title?: string;
}

const { title = 'Arthur Jeunechamp — Product Designer' } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Portfolio d'Arthur Jeunechamp — Product Designer curieux et créatif" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/images/logo/Icon 180px - Light.png" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/png" href="/images/logo/Icon 180px - Dark.png" media="(prefers-color-scheme: dark)" />
    <link rel="apple-touch-icon" href="/images/logo/Icon 180px - Light.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=SUSE:wght@300;400;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/tokens.css';
  @import '../styles/reset.css';
  @import '../styles/typography.css';
</style>
