---
import Layout from './Layout.astro';
import MenuHome from '../components/MenuHome.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  bgColor: string;
  textColor: string;
  chips: string[];
  pageTitle?: string;
}

const {
  title,
  bgColor,
  textColor,
  chips,
  pageTitle,
} = Astro.props;
---

<Layout title={pageTitle || title}>
  <MenuHome />

  <main>
    <div class="project-container" style={`--project-bg: ${bgColor}; --project-text: ${textColor};`}>
      <div class="project-container__inner">
        <!-- Header visual -->
        <div class="project-header">
          <slot name="header" />
        </div>

        <!-- Title -->
        <h2 class="h2-bold project-title">{title}</h2>

        <!-- Chips -->
        <div class="project-chips">
          {chips.map((chip) => <span class="project-chip">{chip}</span>)}
        </div>

        <!-- Content slot -->
        <slot />
      </div>
    </div>

    <!-- Other projects thumbnails -->
    <section class="project-others">
      <slot name="thumbnails" />
    </section>

    <!-- Footer -->
    <Footer patternSrc="/images/footer/Motif UI UX pour boucle.png" />
  </main>
</Layout>

<style>
  .project-container {
    background-color: var(--project-bg);
    color: var(--project-text);
    margin: 0 var(--space-24);
    border-radius: 0 0 var(--radius-md) var(--radius-md);
  }

  .project-container__inner {
    max-width: 682px;
    margin: 0 auto;
    padding: 0 var(--space-24) var(--space-128);
    display: flex;
    flex-direction: column;
    gap: var(--space-32);
  }

  .project-header {
    position: relative;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    width: 100%;
  }

  .project-title {
    color: var(--project-text);
  }

  .project-chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-8);
  }

  .project-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 4px 12px;
    background-color: var(--color-blue-500);
    color: var(--color-cream);
    border-radius: var(--radius-full);
    font-size: 16px;
    font-weight: var(--font-weight-regular);
    white-space: nowrap;
  }

  .project-others {
    display: flex;
    gap: var(--space-48);
    padding: var(--space-64) var(--content-padding);
    justify-content: center;
  }
</style>

<style is:global>
  .project-text {
    font-size: 16px;
    font-weight: var(--font-weight-regular);
    line-height: 1.6;
  }

  .project-image {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: var(--space-24);
    overflow: hidden;
  }

  .project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .project-image img.loaded {
    opacity: 1;
  }

  .project-image video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .parallax-layer {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>

<script>
  function initParallax() {
    const header = document.querySelector('.project-header');
    if (!header) return;

    const layers = header.querySelectorAll('.parallax-layer');
    if (!layers.length) return;

    function onScroll() {
      const rect = header!.getBoundingClientRect();
      const windowHeight = window.innerHeight;

      // Only apply when header is in viewport
      if (rect.bottom < 0 || rect.top > windowHeight) return;

      const scrollY = window.scrollY;

      layers.forEach((layer, index) => {
        const speed = index * 0.08;
        const yOffset = scrollY * speed;
        (layer as HTMLElement).style.transform = `translateY(${yOffset}px)`;
      });
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  function initFadeIn() {
    const images = document.querySelectorAll('.project-image img');
    images.forEach((img) => {
      const el = img as HTMLImageElement;
      if (el.complete) {
        el.classList.add('loaded');
      } else {
        el.addEventListener('load', () => el.classList.add('loaded'));
      }
    });
  }

  document.addEventListener('DOMContentLoaded', () => { initParallax(); initFadeIn(); });
  document.addEventListener('astro:page-load', () => { initParallax(); initFadeIn(); });
</script>
