---
import Layout from './Layout.astro';
import MenuHome from '../components/MenuHome.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  bgColor: string;
  textColor: string;
  chips: string[];
  pageTitle?: string;
}

const {
  title,
  bgColor,
  textColor,
  chips,
  pageTitle,
} = Astro.props;
---

<Layout title={pageTitle || title}>
  <MenuHome />

  <main>
    <div class="project-container" style={`--project-bg: ${bgColor}; --project-text: ${textColor};`}>
      <div class="project-container__inner">
        <!-- Header visual -->
        <div class="project-header">
          <slot name="header" />
        </div>

        <!-- Title -->
        <h2 class="h2-bold project-title">{title}</h2>

        <!-- Chips -->
        <div class="project-chips">
          {chips.map((chip) => <span class="project-chip">{chip}</span>)}
        </div>

        <!-- Content slot -->
        <slot />
      </div>
    </div>

    <!-- Image modal -->
    <div class="project-modal" id="project-modal">
      <div class="project-modal__backdrop"></div>
      <div class="project-modal__content">
        <img class="project-modal__img" src="" alt="" />
      </div>
    </div>

    <!-- Other projects thumbnails -->
    <section class="project-others">
      <slot name="thumbnails" />
    </section>

    <!-- Footer -->
    <Footer patternSrc="/images/footer/Motif UI UX pour boucle.png" />
  </main>
</Layout>

<style>
  .project-container {
    background-color: var(--project-bg);
    color: var(--project-text);
    margin: 0 var(--space-24);
    border-radius: 0 0 var(--radius-md) var(--radius-md);
  }

  .project-container__inner {
    max-width: 682px;
    margin: 0 auto;
    padding: 0 var(--space-24) var(--space-128);
    display: flex;
    flex-direction: column;
    gap: var(--space-32);
  }

  .project-header {
    position: relative;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    width: 100%;
  }

  .project-title {
    color: var(--project-text);
  }

  .project-chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-8);
  }

  .project-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 4px 12px;
    background-color: var(--project-text);
    color: var(--project-bg);
    border-radius: var(--radius-full);
    font-size: 16px;
    font-weight: var(--font-weight-regular);
    white-space: nowrap;
  }

  .project-others {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-48);
    padding: var(--space-64) var(--content-padding);
    justify-content: center;
  }
</style>

<style is:global>
  .project-text {
    font-size: 16px;
    font-weight: var(--font-weight-regular);
    line-height: 1.6;
  }

  .project-image {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: var(--space-24);
    overflow: hidden;
    cursor: pointer;
  }

  .project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-image video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .parallax-layer {
    position: absolute;
    inset: -15%;
    width: 130%;
    height: 130%;
    object-fit: cover;
  }

  .project-modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .project-modal--open {
    pointer-events: auto;
    opacity: 1;
  }

  .project-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.85);
  }

  .project-modal__content {
    position: relative;
    max-width: 90vw;
    max-height: 90vh;
    transform: scale(0.85);
    transition: transform 0.3s ease;
  }

  .project-modal--open .project-modal__content {
    transform: scale(1);
  }

  .project-modal__img {
    width: 100%;
    height: 100%;
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: var(--radius-md);
  }
</style>

<script>
  function initParallax() {
    const header = document.querySelector('.project-header');
    if (!header) return;

    const layers = header.querySelectorAll('.parallax-layer');
    if (!layers.length) return;

    // Mouse tracking speeds per layer: 2%, 6%, 11%
    const mouseSpeeds = [0.02, 0.07, 0.13];
    let mouseX = 0;
    let mouseY = 0;
    let currentMouseX = 0;
    let currentMouseY = 0;
    let animating = false;

    function updateTransforms() {
      const rect = header!.getBoundingClientRect();
      const windowHeight = window.innerHeight;
      const scrollY = window.scrollY;

      // Smooth lerp for mouse movement
      currentMouseX += (mouseX - currentMouseX) * 0.08;
      currentMouseY += (mouseY - currentMouseY) * 0.08;

      layers.forEach((layer, index) => {
        const scrollSpeed = index * 0.08;
        const yScroll = scrollY * scrollSpeed;
        const mouseSpeed = mouseSpeeds[index] || mouseSpeeds[mouseSpeeds.length - 1];
        const xMouse = currentMouseX * mouseSpeed;
        const yMouse = currentMouseY * mouseSpeed;
        (layer as HTMLElement).style.transform = `translate(${xMouse}px, ${yScroll + yMouse}px)`;
      });

      animating = true;
      requestAnimationFrame(updateTransforms);
    }

    window.addEventListener('mousemove', (e) => {
      // Offset from center of viewport
      mouseX = (e.clientX - window.innerWidth / 2);
      mouseY = (e.clientY - window.innerHeight / 2);
    });

    // Start animation loop
    updateTransforms();
  }

  function initModal() {
    const modal = document.getElementById('project-modal');
    if (!modal) return;

    const modalImg = modal.querySelector('.project-modal__img') as HTMLImageElement;
    const backdrop = modal.querySelector('.project-modal__backdrop');

    function closeModal() {
      modal.classList.remove('project-modal--open');
      modal.addEventListener('transitionend', () => {
        modalImg.src = '';
      }, { once: true });
    }

    document.querySelectorAll('.project-image').forEach((item) => {
      item.addEventListener('click', () => {
        const img = item.querySelector('img');
        if (!img) return;
        modalImg.src = img.src;
        modalImg.alt = img.alt;
        modal.classList.add('project-modal--open');
      });
    });

    backdrop?.addEventListener('click', closeModal);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.classList.contains('project-modal--open')) {
        closeModal();
      }
    });
  }

  function initScrollFadeIn() {
    // Add fade-in class to all content elements
    const elements = document.querySelectorAll('.project-image, .project-text, .project-title, .project-chips, .project-others');
    elements.forEach((el) => el.classList.add('fade-in'));

    const fadeEls = document.querySelectorAll('.fade-in');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('fade-in--visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    fadeEls.forEach((el) => observer.observe(el));
  }

  document.addEventListener('DOMContentLoaded', () => { initParallax(); initModal(); initScrollFadeIn(); });
  document.addEventListener('astro:page-load', () => { initParallax(); initModal(); initScrollFadeIn(); });
</script>
