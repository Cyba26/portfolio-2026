---
import Layout from './Layout.astro';
import MenuHome from '../components/MenuHome.astro';
import BlocLink from '../components/BlocLink.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  iconSrc: string;
  pageTitle?: string;
}

const { title, description, iconSrc, pageTitle } = Astro.props;
---

<Layout title={pageTitle || title}>
  <MenuHome />

  <main>
    <section class="skill-hero">
      <img class="skill-hero__icon" src={iconSrc} alt="" />
      <h1 class="h1-bold">{title}</h1>
      <p class="text-md skill-hero__desc">{description}</p>
    </section>

    <section class="skill-content">
      <slot />
    </section>

    <div class="skill-modal" id="skill-modal">
      <div class="skill-modal__backdrop"></div>
      <div class="skill-modal__content">
        <img class="skill-modal__img" src="" alt="" />
      </div>
    </div>

    <section class="contact">
      <h2 class="h1-bold">Envie d'en voir plus ? D'en discuter ?</h2>
      <div class="contact__links">
        <BlocLink
          label="Arthur Jeunechamp"
          iconSrc="/images/icons/Icon - LK.png"
          href="https://www.linkedin.com/in/arthur-jeunechamp/"
        />
        <BlocLink
          label="arthur.jeunechamp@gmail.com"
          iconSrc="/images/icons/Icon - Mail.png"
          href="mailto:arthur.jeunechamp@gmail.com"
        />
        <BlocLink
          label="CV - Arthur Jeunechamp"
          iconSrc="/images/icons/Icon - CV.png"
        />
      </div>
    </section>

    <Footer patternSrc="/images/footer/Motif UI UX pour boucle.png" />
  </main>
</Layout>

<style>
  .skill-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-32);
    padding-top: var(--margin-page-up);
    padding-left: var(--content-padding);
    padding-right: var(--content-padding);
  }

  .skill-hero__icon {
    width: 300px;
    height: 300px;
    object-fit: contain;
    transform: scale(0.92);
  }

  .skill-hero__desc {
    color: var(--color-blue-400);
    text-align: center;
    max-width: 400px;
  }

  .skill-content {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 600px));
    justify-content: center;
    gap: var(--space-48);
    padding: var(--space-64) var(--content-padding);
  }

  @media (max-width: 768px) {
    .skill-content {
      grid-template-columns: 1fr;
      max-width: 600px;
      margin: 0 auto;
    }
  }

  .contact {
    display: flex;
    flex-direction: column;
    gap: var(--space-32);
    padding: var(--space-128) var(--content-padding) var(--space-64);
  }

  .contact__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-16) var(--space-32);
  }
</style>

<style is:global>
  .skill-item {
    width: 100%;
    aspect-ratio: 1;
    border-radius: var(--space-24);
    overflow: hidden;
    cursor: pointer;
  }

  .skill-item img,
  .skill-item video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .skill-modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .skill-modal--open {
    pointer-events: auto;
    opacity: 1;
  }

  .skill-modal__backdrop {
    position: absolute;
    inset: 0;
    background: var(--color-blue-modal);
  }

  .skill-modal__content {
    position: relative;
    max-width: 90vw;
    max-height: 90vh;
    transform: scale(0.85);
    transition: transform 0.3s ease;
  }

  .skill-modal--open .skill-modal__content {
    transform: scale(1);
  }

  .skill-modal__img {
    width: 100%;
    height: 100%;
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: var(--radius-md);
  }
</style>

<script>
  function initModal() {
    const modal = document.getElementById('skill-modal');
    if (!modal) return;

    const modalImg = modal.querySelector('.skill-modal__img') as HTMLImageElement;
    const backdrop = modal.querySelector('.skill-modal__backdrop');

    function closeModal() {
      modal.classList.remove('skill-modal--open');
      modal.addEventListener('transitionend', () => {
        modalImg.src = '';
      }, { once: true });
    }

    document.querySelectorAll('.skill-item').forEach((item) => {
      item.addEventListener('click', () => {
        const img = item.querySelector('img');
        if (!img) return;
        modalImg.src = img.src;
        modalImg.alt = img.alt;
        modal.classList.add('skill-modal--open');
      });
    });

    backdrop?.addEventListener('click', closeModal);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.classList.contains('skill-modal--open')) {
        closeModal();
      }
    });
  }

  document.addEventListener('DOMContentLoaded', initModal);
  document.addEventListener('astro:page-load', initModal);
</script>
