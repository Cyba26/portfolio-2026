---
import Layout from '../layouts/Layout.astro';
import MenuHome from '../components/MenuHome.astro';
import PhotoTitle from '../components/PhotoTitle.astro';
import SectionTitle from '../components/SectionTitle.astro';
import BlocProject from '../components/BlocProject.astro';
import BlocSkills from '../components/BlocSkills.astro';
import BlocLink from '../components/BlocLink.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <MenuHome />

  <main>
    <!-- ════ Cercle scroll ════ -->
    <div class="presentation__circle" id="presentation-circle"></div>

    <!-- ════ Hero ════ -->
    <section class="hero">
      <img
        class="hero__pattern"
        src="/images/hero/motif-hero.png"
        alt=""
      />
    </section>

    <!-- ════ Présentation ════ -->
    <section class="presentation fade-in" id="presentation">
      <PhotoTitle
        photoSrc="/images/photo.jpg"
        lineLight="Je suis"
        lineBold="Curieux et créatif"
      />
      <p class="text-md presentation__text">Product Designer / Designer UI-UX avec plus de&nbsp;5&nbsp;ans d'expérience en&nbsp;agence et&nbsp;secteur public. J'accompagne les&nbsp;équipes de&nbsp;l'idéation à&nbsp;la&nbsp;livraison&nbsp;: ateliers de&nbsp;cadrage, conception&nbsp;UX/UI, et&nbsp;review avec&nbsp;les&nbsp;devs. Mon&nbsp;approche mêle rigueur méthodologique, sensibilité graphique et&nbsp;veille constante sur&nbsp;les&nbsp;bonnes&nbsp;pratiques.</p>
    </section>

    <!-- ════ Mes projets ════ -->
    <SectionTitle title="Mes projets" />

    <BlocProject
      clientLight="Bouygues"
      clientBold="Quickconnect"
      description={"Réinventer la gestion de\u00A0l'information sur les\u00A0chantiers"}
      chips={["UI Design", "UX Design", "Design System", "BTP & Construction"]}
      imageSrc="/images/projects/Bouygues/Mockup_Home_1500px.png"
      backgroundSrc="/images/projects/Bouygues/Background.jpg"
      href="/projets/bouygues"
    />

    <BlocProject
      clientLight="FDJ"
      clientBold="Innomillion Vivatech"
      description={"Gamifier une expérience pour valoriser\u00A0l'innovation"}
      chips={["UI Design", "UX Design", "Événementiel & Salon", "Jeux d'argent"]}
      imageSrc="/images/projects/FDJ/Mockup_Home_1500px.png"
      backgroundSrc="/images/projects/FDJ/Background.png"
      href="/projets/fdj"
    />

    <BlocProject
      clientLight="Thales"
      clientBold="Parking"
      description={"Réinventer le parcours utilisateur dans son expérience du\u00A0parking"}
      chips={["UI Design", "UX Design", "Design System", "Écologie", "Parking & Transport"]}
      imageSrc="/images/projects/Thales/Mockup_Home_1500px.png"
      backgroundSrc="/images/projects/Thales/Background.png"
      href="/projets/thales"
    />

    <BlocProject
      clientLight="Colas"
      clientBold="Management Assist'"
      description={"Gamifier un outil de remontée terrain sur les\u00A0chantiers"}
      chips={["UI Design", "UX Design", "Charte Graphique", "BTP & Construction"]}
      imageSrc="/images/projects/Colas/Mockup_Home_1500px.png"
      backgroundSrc="/images/projects/Colas/Background.jpg"
      href="/projets/colas"
    />

    <!-- ════ Aperçu ════ -->
    <section class="apercu fade-in">
      <h2 class="h1-bold apercu__dots">...</h2>
      <div class="apercu__card">
        <h3 class="h3-bold">Ce n'est qu'un aperçu !</h3>
        <p class="text-md apercu__text">Plateforme médicale, e-commerce pour des&nbsp;voyages linguistiques, RH&nbsp;et&nbsp;newsletters, gamification pour les&nbsp;jeux d'argent… j'ai eu&nbsp;l'opportunité de&nbsp;travailler sur de&nbsp;nombreux projets variés. N'hésitez pas à&nbsp;me&nbsp;contacter pour en&nbsp;découvrir&nbsp;davantage&nbsp;!</p>
      </div>
    </section>

    <!-- ════ Mes skills en plus ════ -->
    <SectionTitle title="Mes skills en plus" />

    <section class="skills fade-in" id="skills">
      <BlocSkills
        title={"Je crée des\u00A0illus"}
        description={"Dessiner sans dépasser des lignes la plupart du\u00A0temps"}
        imageSrc="/images/skills/illustration/Thumbnail_illustration.png"
        href="/skills/illustration"
      />
      <BlocSkills
        title={"Je conçois des\u00A0jeux"}
        description={"Y jouer c'est bien, les faire c'est encore\u00A0mieux\u00A0!"}
        imageSrc="/images/skills/developpement/Thumbnail_developpement.png"
        href="/skills/developpement"
      />
      <BlocSkills
        title={"Je modélise en\u00A03D"}
        description={"Pour ajouter une nouvelle dimension à\u00A0mon\u00A0travail"}
        imageSrc="/images/skills/modelisation/Thumbnail_modelisation.png"
        href="/skills/modelisation"
      />
    </section>

    <!-- ════ Contact ════ -->
    <section class="contact fade-in" id="contact">
      <h2 class="h1-bold">Envie d'en voir plus&nbsp;? D'en&nbsp;discuter&nbsp;?</h2>
      <div class="contact__links">
        <BlocLink
          label="Arthur Jeunechamp"
          iconSrc="/images/icons/Icon - LK.png"
          href="https://www.linkedin.com/in/arthur-jeunechamp/"
        />
        <BlocLink
          label="arthur.jeunechamp@gmail.com"
          iconSrc="/images/icons/Icon - Mail.png"
          href="mailto:arthur.jeunechamp@gmail.com"
        />
        <BlocLink
          label="CV - Arthur Jeunechamp"
          iconSrc="/images/icons/Icon - CV.png"
          href="https://drive.google.com/file/d/1zWiOOj6Dbw4ROiFs6VTjmRIGrcbqwxu0/view?usp=drive_link"
        />
      </div>
    </section>

    <!-- ════ Footer ════ -->
    <Footer patternSrc="/images/footer/Motif UI UX pour boucle.png" />
  </main>
</Layout>

<style>
  main {
    position: relative;
    overflow-x: hidden;
  }

  /* ── Hero ── */
  .hero {
    position: relative;
    width: 100%;
    height: 686px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 0;
  }

  .hero__pattern {
    width: 3200px;
    max-width: none;
    height: auto;
    object-fit: cover;
    will-change: transform, opacity;
  }

  @media (max-width: 768px) {
    .hero__pattern {
      width: 2240px;
    }
  }

  /* ── Cercle scroll ── */
  .presentation__circle {
    position: absolute;
    left: 50%;
    top: 0;
    width: 800px;
    height: 800px;
    margin-left: -400px;
    border-radius: var(--radius-full);
    background: var(--color-blue-850);
    pointer-events: none;
    transform: scale(0.2);
    z-index: 1;
  }

  /* ── Présentation ── */
  .presentation {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-32);
    padding: var(--space-128) var(--content-padding) var(--space-48);
    z-index: 3;
  }

  .presentation__text {
    max-width: 600px;
    text-align: center;
    color: var(--color-blue-400);
  }

  /* ── Aperçu ── */
  .apercu {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: var(--space-32) var(--content-padding);
  }

  .apercu__dots {
    margin-bottom: var(--space-16);
  }

  .apercu__card {
    width: 100%;
    max-width: 1000px;
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
    align-items: center;
    justify-content: center;
    padding: var(--space-32);
    background-color: var(--color-blue-850);
    border-radius: var(--radius-md);
  }

  .apercu__text {
    color: var(--color-blue-400);
  }

  /* ── Skills ── */
  .skills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-64);
    padding: 0 var(--content-padding);
  }

  /* ── Contact ── */
  .contact {
    display: flex;
    flex-direction: column;
    gap: var(--space-32);
    padding: var(--space-128) var(--content-padding) var(--space-64);
  }

  .contact__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-16) var(--space-32);
  }
</style>

<script>
  function initScrollEffects() {
    const section = document.getElementById('presentation');
    const circle = document.getElementById('presentation-circle');
    const heroPattern = document.querySelector('.hero__pattern') as HTMLElement;
    const hero = document.querySelector('.hero') as HTMLElement;
    if (!section || !circle) return;

    // Position circle centered between PhotoTitle and description text
    function positionCircle() {
      const photoTitle = section.querySelector('.photo-title') as HTMLElement;
      const desc = section.querySelector('.presentation__text') as HTMLElement;
      if (photoTitle && desc) {
        const titleBottom = section.offsetTop + photoTitle.offsetTop + photoTitle.offsetHeight;
        const descTop = section.offsetTop + desc.offsetTop;
        const centerY = (titleBottom + descTop) / 2;
        const circleH = 800;
        circle.style.top = `${centerY - circleH / 2 - 20}px`;
      } else {
        const sectionTop = section.offsetTop;
        const sectionH = section.offsetHeight;
        const circleH = 800;
        circle.style.top = `${sectionTop + sectionH / 2 - circleH / 2}px`;
      }
    }

    function onScroll() {
      const rect = section.getBoundingClientRect();
      const viewH = window.innerHeight;

      // Circle zoom
      const scrollRange = viewH + viewH * 0.5;
      const progress = Math.max(0, Math.min(1, (viewH - rect.top) / scrollRange));
      const scale = 0.2 + progress * 1.4;
      circle.style.transform = `scale(${scale})`;

      // Hero parallax: moves at 50% scroll speed + fades from 100% to 50%
      if (heroPattern && hero) {
        const scrollY = window.scrollY;
        const heroH = hero.offsetHeight;
        const parallaxY = scrollY * 0.5;
        const fadeProgress = Math.min(1, scrollY / heroH);
        const opacity = 1 - fadeProgress * 0.9;
        heroPattern.style.transform = `translateY(${parallaxY}px)`;
        heroPattern.style.opacity = `${opacity}`;
      }
    }

    positionCircle();
    window.addEventListener('resize', positionCircle);
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // Fade-in on scroll with IntersectionObserver
    const fadeEls = document.querySelectorAll('.fade-in');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('fade-in--visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    fadeEls.forEach((el) => observer.observe(el));
  }

  document.addEventListener('DOMContentLoaded', initScrollEffects);
  document.addEventListener('astro:page-load', initScrollEffects);
</script>
